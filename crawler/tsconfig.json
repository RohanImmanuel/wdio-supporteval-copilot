{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "types": ["node", "@wdio/globals/types", "mocha"]
  },
  "include": ["src/**/*", "tests/**/*", "wdio.conf.ts"],
  "exclude": ["node_modules", "dist"]
}
